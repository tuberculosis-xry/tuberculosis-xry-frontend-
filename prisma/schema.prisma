model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// OHIF Study List — patient/study details (all from DB, no hardcoded list)
model OhifStudy {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  studyInstanceUID  String   @unique
  patientName       String
  patientId         String
  mrn               String
  studyDate         String
  studyTime         String?  // e.g. "14:05" or "02:05 PM"
  studyDescription  String
  modality          String
  accessionNumber   String
  instances         Int
  seriesCount       Int?    // from instance store when known; null if not yet computed
  availableModes    String[] // e.g. ["basic", "segmentation", "tmtv"]
  patientSex        String?  // M / F / O
  patientBirthDate  String?  // YYYY-MM-DD
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([mrn])
  @@index([patientName])
  @@index([studyDate])
}

/// OHIF DICOM instances — raw DICOM bytes per instance (no PACS). One doc per SOP instance.
model OhifInstance {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  studyInstanceUID   String
  seriesInstanceUID  String
  sopInstanceUID     String   @unique
  patientId          String
  mrn                String
  instanceNumber     Int
  dicomBytes         Bytes
  createdAt          DateTime @default(now())

  @@index([studyInstanceUID])
  @@index([seriesInstanceUID])
  @@index([studyInstanceUID, seriesInstanceUID])
  @@index([mrn])
}

/// Per-instance DICOM viewport annotations (drawings, shapes, comments, marks).
/// One record per (study, series, sop, user). Edits are stored as JSON payload; save overwrites.
model OhifViewportAnnotation {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  studyInstanceUID   String
  seriesInstanceUID  String
  sopInstanceUID     String
  userId             String   // Firebase UID of the user who created/saved
  payload            String   // JSON array of annotation items (normalized coords 0-1)
  createdAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studyInstanceUID, seriesInstanceUID, sopInstanceUID, userId])
  @@index([studyInstanceUID])
  @@index([userId])
}

/// Stored measurement reports (STOW "store back") — when user sends measurements to storage.
/// Persists to app DB; optional forward to PACS STOW can be added later.
model OhifMeasurementReport {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  studyInstanceUID  String
  userId            String   // Firebase UID of the user who sent
  payload           String   // JSON: { measurements: Measurement[] }
  createdAt         DateTime @default(now())

  @@index([studyInstanceUID])
  @@index([userId])
}

/// Saved measurements per study + user (Save button). One record per (study, user); overwritten on each Save.
/// Payload = full Measurement[] JSON including geometry and imageId for re-draw on canvas.
model OhifSavedMeasurements {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  studyInstanceUID  String
  userId            String
  payload           String   // JSON: full Measurement[] with geometry, imageId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studyInstanceUID, userId])
  @@index([studyInstanceUID])
  @@index([userId])
}
