generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model TuberculosisDiagnosis {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  timestamp       DateTime @default(now())
  image           Bytes
  class           String   @default("normal")
  userId          String   // Firebase UID of the user who ran the scan
  confidenceScore Float    // 0–1 from model
  patientName     String?  // from DICOM or label
  patientId       String?  // DICOM Patient ID
  patientSex      String?  // DICOM Patient Sex (M/F/O)
  patientBirthDate String? // DICOM Patient Birth Date (YYYYMMDD)
  studyDate       String?  // DICOM Study Date (YYYYMMDD)
  studyTime       String?  // DICOM Study Time (optional)

  @@index([userId], name: "idx_userId")
  @@index([timestamp(sort: Desc)], name: "idx_timestamp")
  @@index([userId, timestamp(sort: Desc)], name: "idx_userId_timestamp")
}

/// models for NextAuth.js / auth

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
}

