Dockerfile*
.cursor
.vscode
.idea
*.swp
*.swo

# Docs and misc
README*
LICENSE
*.md
.DS_Store
Thumbs.db

# Tests and tooling (not needed in production image)
coverage
.nyc_output
*.test.*
*.spec.*
__tests__
e2e
.eslintcache
.vercel
